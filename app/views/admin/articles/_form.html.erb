<%= form_with(model: [:admin, article], class: "space-y-6") do |f| %>
  <div class="bg-white rounded-lg shadow-sm p-6">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div class="md:col-span-2"><label class="block text-sm font-medium mb-1">Title *</label><%= f.text_field :title, class: "w-full border rounded-lg px-3 py-2 text-sm" %></div>
      <div><label class="block text-sm font-medium mb-1">Slug</label><%= f.text_field :slug, class: "w-full border rounded-lg px-3 py-2 text-sm bg-gray-50" %></div>
      <div><label class="block text-sm font-medium mb-1">Category</label><%= f.select :category_id, @categories.map{|c|[c.name,c.id]}, {include_blank:"—"}, class: "w-full border rounded-lg px-3 py-2 text-sm" %></div>
      <div class="md:col-span-2"><label class="block text-sm font-medium mb-1">Excerpt</label><%= f.text_area :excerpt, rows: 2, class: "w-full border rounded-lg px-3 py-2 text-sm" %></div>
      <div class="md:col-span-2"><label class="block text-sm font-medium mb-1">Content</label><%= f.text_area :content, rows: 20, class: "w-full border rounded-lg px-3 py-2 text-sm font-mono" %></div>
      <div><label class="block text-sm font-medium mb-1">Published At</label><%= f.datetime_local_field :published_at, class: "w-full border rounded-lg px-3 py-2 text-sm" %></div>
      <div class="flex items-end"><label class="inline-flex items-center gap-2"><%= f.check_box :published, class: "rounded border-gray-300 text-indigo-600" %> Published</label></div>
    </div>
  </div>
  <div class="flex gap-3">
    <%= f.submit article.new_record? ? "Create" : "Update", class: "bg-indigo-600 text-white px-6 py-2 rounded-lg text-sm cursor-pointer" %>
    <a href="/admin/articles" class="text-gray-500 px-4 py-2 text-sm">Cancel</a>
  </div>
<% end %>

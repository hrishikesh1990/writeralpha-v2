<div class="max-w-7xl mx-auto px-4 py-8">
  <h1 class="text-3xl font-bold text-gray-900 mb-2">Gemstone Directory</h1>
  <p class="text-gray-600 mb-8">Explore our collection of <%= @gemstones.count %> gemstones. Use filters to find your perfect crystal.</p>
  <div class="flex flex-col lg:flex-row gap-8">
    <!-- Sidebar -->
    <aside class="lg:w-72 flex-shrink-0">
      <div class="bg-white rounded-xl border border-gray-200 p-5 sticky top-20 space-y-5">
        <h2 class="font-bold text-gray-900">Filters</h2>
        <% if @colors.any? %>
        <div><h3 class="text-sm font-semibold text-gray-700 mb-2">Color</h3>
          <div class="flex flex-wrap gap-1.5"><% @colors.each do |c| %>
            <a href="<%= gemstones_by_color_path(color: c.slug) %>" class="text-xs px-2.5 py-1 rounded-full border border-gray-300 text-gray-600 hover:border-purple-500 hover:text-purple-700 transition"><%= c.name %></a>
          <% end %></div></div>
        <% end %>
        <% if @healing_powers.any? %>
        <div><h3 class="text-sm font-semibold text-gray-700 mb-2">Healing Power</h3>
          <div class="flex flex-wrap gap-1.5"><% @healing_powers.each do |hp| %>
            <a href="<%= gemstones_by_healing_path(value: hp.slug) %>" class="text-xs px-2.5 py-1 rounded-full border border-gray-300 text-gray-600 hover:border-purple-500 hover:text-purple-700 transition"><%= hp.name %></a>
          <% end %></div></div>
        <% end %>
        <% if @birth_months.any? %>
        <div><h3 class="text-sm font-semibold text-gray-700 mb-2">Birth Month</h3>
          <div class="flex flex-wrap gap-1.5"><% @birth_months.each do |bm| %>
            <a href="<%= gemstones_by_birth_month_path(value: bm.name.downcase) %>" class="text-xs px-2.5 py-1 rounded-full border border-gray-300 text-gray-600 hover:border-purple-500 hover:text-purple-700 transition"><%= bm.name %></a>
          <% end %></div></div>
        <% end %>
        <% if @zodiac_signs.any? %>
        <div><h3 class="text-sm font-semibold text-gray-700 mb-2">Zodiac</h3>
          <div class="flex flex-wrap gap-1.5"><% @zodiac_signs.each do |z| %>
            <a href="<%= gemstones_by_zodiac_path(value: z.slug) %>" class="text-xs px-2.5 py-1 rounded-full border border-gray-300 text-gray-600 hover:border-purple-500 hover:text-purple-700 transition"><%= z.name %></a>
          <% end %></div></div>
        <% end %>
        <% if @letters.any? %>
        <div><h3 class="text-sm font-semibold text-gray-700 mb-2">A-Z</h3>
          <div class="flex flex-wrap gap-1"><% @letters.each do |l| %>
            <a href="<%= gemstones_by_letter_path(value: l.downcase) %>" class="w-8 h-8 flex items-center justify-center text-xs rounded border border-gray-300 text-gray-600 hover:bg-purple-700 hover:text-white hover:border-purple-700 transition font-semibold"><%= l %></a>
          <% end %></div></div>
        <% end %>
        <a href="<%= gemstones_path %>" class="block text-center text-sm text-purple-700 hover:text-purple-800">Clear All Filters</a>
      </div>
    </aside>
    <!-- Grid -->
    <div class="flex-1">
      <%= render partial: "gemstones/grid", locals: { gemstones: @gemstones } %>
    </div>
  </div>
</div>

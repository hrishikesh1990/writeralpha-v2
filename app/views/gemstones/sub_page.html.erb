<div class="max-w-4xl mx-auto px-4 py-8">
  <nav class="text-sm text-gray-500 mb-6"><a href="/" class="hover:text-purple-700">Home</a> › <a href="/gemstones" class="hover:text-purple-700">Gemstones</a> › <a href="<%= gemstone_path(@gemstone) %>" class="hover:text-purple-700"><%= @gemstone.name %></a> › <span class="text-gray-900"><%= @page_title %></span></nav>
  <span class="text-4xl block mb-3"><%= @page_icon %></span>
  <h1 class="text-3xl font-bold text-gray-900 mb-6"><%= @page_title %></h1>
  <article class="prose prose-lg max-w-none mb-10">
    <% if @content.present? %><%= simple_format(@content) %>
    <% else %><div class="bg-yellow-50 border border-yellow-200 rounded-lg p-6 text-center"><p class="text-yellow-800">This guide is coming soon. Check back for a comprehensive guide.</p></div><% end %>
  </article>
  <div class="border-t pt-8 mt-8">
    <h2 class="text-xl font-bold text-gray-900 mb-4">More About <%= @gemstone.name %></h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-2">
      <% @gemstone.hub_sub_pages.each do |sp| %>
        <a href="/gemstones/<%= @gemstone.slug %>/<%= sp[:path] %>" class="flex items-center gap-2 text-purple-700 hover:text-purple-800 py-1 text-sm"><span><%= sp[:icon] %></span> <%= sp[:title] %></a>
      <% end %>
    </div>
    <a href="<%= gemstone_path(@gemstone) %>" class="inline-block mt-4 text-purple-700 hover:text-purple-800 font-medium">← Back to <%= @gemstone.name %> Overview</a>
  </div>
</div>

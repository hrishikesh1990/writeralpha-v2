<h1 class="text-2xl font-bold mb-6">Edit Redirect</h1>
<%= form_with(model: [:admin, @redirect], class: "space-y-4") do |f| %>
  <div class="bg-white rounded-lg shadow-sm p-6 grid grid-cols-1 md:grid-cols-3 gap-4">
    <div><label class="block text-sm font-medium mb-1">Old Path</label><%= f.text_field :old_path, class: "w-full border rounded-lg px-3 py-2 text-sm font-mono" %></div>
    <div><label class="block text-sm font-medium mb-1">New Path</label><%= f.text_field :new_path, class: "w-full border rounded-lg px-3 py-2 text-sm font-mono" %></div>
    <div><label class="block text-sm font-medium mb-1">Status Code</label><%= f.number_field :status_code, class: "w-full border rounded-lg px-3 py-2 text-sm" %></div>
  </div>
  <%= f.submit "Update", class: "bg-gray-800 text-white px-6 py-2 rounded-lg text-sm cursor-pointer" %>
<% end %>

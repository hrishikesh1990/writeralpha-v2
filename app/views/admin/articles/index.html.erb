<div class="flex justify-between items-center mb-6">
  <h1 class="text-2xl font-bold">Articles (<%= @articles.count %>)</h1>
  <a href="/admin/articles/new" class="bg-indigo-600 text-white px-4 py-2 rounded-lg text-sm">+ New</a>
</div>
<div class="bg-white rounded-lg shadow-sm">
  <% if @articles.any? %><table class="w-full"><tbody>
    <% @articles.each do |a| %><tr class="border-t hover:bg-gray-50">
      <td class="px-4 py-3"><span class="font-medium"><%= a.title.truncate(60) %></span></td>
      <td class="px-4 py-3 text-sm text-gray-500"><%= a.category&.name %></td>
      <td class="px-4 py-3 text-right"><a href="<%= edit_admin_article_path(a) %>" class="text-xs text-indigo-600">Edit</a>
        <a href="<%= admin_article_path(a) %>" data-turbo-method="delete" data-turbo-confirm="Delete?" class="text-xs text-red-500 ml-2">Del</a></td>
    </tr><% end %>
  </tbody></table><% else %><p class="p-6 text-gray-500 text-center">No articles yet.</p><% end %>
</div>

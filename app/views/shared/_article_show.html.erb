<div class="max-w-4xl mx-auto px-4 py-8">
  <nav class="text-sm text-gray-500 mb-6"><a href="/" class="hover:text-purple-700">Home</a> › <% if breadcrumb_section %><a href="<%= breadcrumb_path %>" class="hover:text-purple-700"><%= breadcrumb_section %></a> › <% end %><span class="text-gray-900"><%= title %></span></nav>
  <h1 class="text-3xl font-bold text-gray-900 mb-4"><%= title %></h1>
  <% if article %>
    <% if article.respond_to?(:featured_image_url) && article.featured_image_url.present? %>
      <div class="w-full h-64 md:h-80 rounded-xl overflow-hidden mb-6">
        <img src="<%= article.featured_image_url %>" alt="<%= title %>" class="w-full h-full object-cover">
      </div>
    <% end %>
    <% if article.respond_to?(:published_at) && article.published_at %><p class="text-sm text-gray-400 mb-6"><%= article.published_at.strftime("%B %d, %Y") %></p><% end %>
    <article class="prose prose-lg max-w-none"><%= render_content(article.content) %></article>
  <% else %>
    <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-6 text-center"><p class="text-yellow-800">Content coming soon.</p></div>
  <% end %>
</div>

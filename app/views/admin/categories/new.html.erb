<h1 class="text-2xl font-bold mb-6">New Category</h1>
<%= form_with(model: [:admin, @category], class: "space-y-4") do |f| %>
  <div class="bg-white rounded-lg shadow-sm p-6 grid grid-cols-1 md:grid-cols-2 gap-4">
    <div><label class="block text-sm font-medium mb-1">Name</label><%= f.text_field :name, class: "w-full border rounded-lg px-3 py-2 text-sm" %></div>
    <div><label class="block text-sm font-medium mb-1">Slug</label><%= f.text_field :slug, class: "w-full border rounded-lg px-3 py-2 text-sm" %></div>
    <div class="md:col-span-2"><label class="block text-sm font-medium mb-1">Description</label><%= f.text_area :description, rows: 2, class: "w-full border rounded-lg px-3 py-2 text-sm" %></div>
    <div><label class="block text-sm font-medium mb-1">Parent</label><%= f.select :parent_id, @parents.map{|p|[p.name,p.id]}, {include_blank:"— None —"}, class: "w-full border rounded-lg px-3 py-2 text-sm" %></div>
  </div>
  <%= f.submit "Create", class: "bg-gray-800 text-white px-6 py-2 rounded-lg text-sm cursor-pointer" %>
<% end %>

<div class="max-w-4xl mx-auto px-4 py-8">
  <nav class="text-sm text-gray-500 mb-6"><a href="/" class="hover:text-purple-700">Home</a> › <a href="/gemstones" class="hover:text-purple-700">Gemstones</a> › <span class="text-gray-900"><%= @gemstone.name %></span></nav>
  <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-3"><%= @gemstone.name %></h1>
  <% if @gemstone.subtitle.present? %><p class="text-lg text-gray-600 mb-6"><%= @gemstone.subtitle %></p><% end %>

  <!-- Quick Stats -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-6">
    <% if @gemstone.mohs_hardness %><div class="bg-purple-50 rounded-lg p-3"><span class="text-xs text-purple-600 font-medium">Mohs Hardness</span><p class="text-lg font-bold text-purple-900"><%= @gemstone.mohs_hardness %></p></div><% end %>
    <% if @gemstone.transparency %><div class="bg-blue-50 rounded-lg p-3"><span class="text-xs text-blue-600 font-medium">Transparency</span><p class="text-base font-bold text-blue-900"><%= @gemstone.transparency.name %></p></div><% end %>
    <% if @gemstone.lustre %><div class="bg-green-50 rounded-lg p-3"><span class="text-xs text-green-600 font-medium">Lustre</span><p class="text-base font-bold text-green-900"><%= @gemstone.lustre.name %></p></div><% end %>
    <% if @gemstone.birth_month %><div class="bg-orange-50 rounded-lg p-3"><span class="text-xs text-orange-600 font-medium">Birth Month</span><p class="text-base font-bold text-orange-900"><%= @gemstone.birth_month.name %></p></div><% end %>
  </div>

  <!-- Tags -->
  <div class="flex flex-wrap gap-2 mb-8">
    <% @gemstone.colors.each do |c| %><a href="<%= gemstones_by_color_path(color: c.slug) %>" class="text-sm bg-gray-100 text-gray-700 px-3 py-1 rounded-full hover:bg-purple-100 hover:text-purple-700 transition"><%= c.name %></a><% end %>
    <% @gemstone.healing_powers.each do |hp| %><a href="<%= gemstones_by_healing_path(value: hp.slug) %>" class="text-sm bg-purple-50 text-purple-700 px-3 py-1 rounded-full hover:bg-purple-100 transition"><%= hp.name %></a><% end %>
    <% @gemstone.zodiac_signs.each do |z| %><a href="<%= gemstones_by_zodiac_path(value: z.slug) %>" class="text-sm bg-indigo-50 text-indigo-700 px-3 py-1 rounded-full hover:bg-indigo-100 transition"><%= z.symbol %> <%= z.name %></a><% end %>
    <% if @gemstone.element.present? %><a href="<%= gemstones_by_element_path(value: @gemstone.element.downcase) %>" class="text-sm bg-red-50 text-red-700 px-3 py-1 rounded-full"><%= @gemstone.element %> Element</a><% end %>
    <% if @gemstone.ruling_planet.present? %><a href="<%= gemstones_by_planet_path(value: @gemstone.ruling_planet.downcase) %>" class="text-sm bg-yellow-50 text-yellow-700 px-3 py-1 rounded-full"><%= @gemstone.ruling_planet %></a><% end %>
  </div>

  <!-- Description -->
  <% if @gemstone.description.present? %><div class="prose prose-lg max-w-none mb-10"><%= simple_format(@gemstone.description) %></div><% end %>

  <!-- 9 Sub-Page Cards -->
  <h2 class="text-2xl font-bold text-gray-900 mb-6">Complete Guide to <%= @gemstone.name %></h2>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
    <% @gemstone.hub_sub_pages.each do |sp| %>
      <a href="/gemstones/<%= @gemstone.slug %>/<%= sp[:path] %>" class="bg-white border border-gray-200 rounded-xl p-5 hover:border-purple-300 hover:shadow-md transition group">
        <span class="text-2xl"><%= sp[:icon] %></span>
        <h3 class="font-semibold text-gray-900 group-hover:text-purple-700 mt-2 text-sm"><%= sp[:title] %></h3>
      </a>
    <% end %>
  </div>
</div>
